# ── PostgreSQL (shared by Next.js and Django) ──────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=headroom
DB_USER=postgres
DB_PASSWORD=your-db-password-here

# ── Next.js ────────────────────────────────────────────────────────────────────
NODE_ENV=development

# ── Django Backend (internal, NOT public) ──────────────────────────────────────
# URL that Next.js uses to reach Django (server-side only)
DJANGO_API_URL=http://localhost:8000

# Shared secret between Next.js proxy and Django (generate a strong random string)
DJANGO_SERVICE_KEY=change-me-generate-a-strong-secret

# ── Django settings ────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-generate-a-strong-secret
DJANGO_DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://your-domain.com

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1

# ── Plaid ──────────────────────────────────────────────────────────────────────
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# ── Fraud (Sardine) ────────────────────────────────────────────────────────────
SARDINE_API_KEY=

# ── JWT ────────────────────────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ── Stripe (subscription billing) ─────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Create these price IDs in your Stripe dashboard (recurring monthly)
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_PRO=price_...
