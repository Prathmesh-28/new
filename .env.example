# ══════════════════════════════════════════════════════════════════════════════
# Headroom — Environment Variables Reference
# Copy to .env.local (Next.js) and services/django-backend/.env (Django)
# ══════════════════════════════════════════════════════════════════════════════

# ── Next.js ────────────────────────────────────────────────────────────────────
NODE_ENV=production

# Django backend URL (internal — Next.js proxy calls this)
DJANGO_API_URL=http://localhost:8000

# Shared secret between Next.js proxy and Django ServiceKeyAuthentication
DJANGO_SERVICE_KEY=change-me-to-a-long-random-string

# ── Database (shared by Next.js auth queries + Django) ─────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=headroom
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_CONN_MAX_AGE=60

# ── Django core ────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=your-50-char-random-secret-key
DJANGO_DEBUG=False
DJANGO_ENV=production
ALLOWED_HOSTS=13.54.2.137,headroom-fc7e3.web.app,localhost
TIME_ZONE=Asia/Kolkata
LOG_LEVEL=INFO

# ── AWS credentials ────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_REGION=ap-southeast-2

# S3 — media / file uploads (leave blank to use local storage)
AWS_STORAGE_BUCKET_NAME=headroom-media-prod
AWS_S3_CUSTOM_DOMAIN=                        # e.g. cdn.headroom.finance (CloudFront)

# SES — transactional email
AWS_SES_REGION_NAME=ap-southeast-2
AWS_SES_FROM_EMAIL=noreply@headroom.finance
AWS_SES_CONFIGURATION_SET=
AWS_SES_SMTP_USER=your-ses-smtp-user
AWS_SES_SMTP_PASSWORD=your-ses-smtp-password

# ── Google OAuth ────────────────────────────────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-...
# Restrict to specific Google Workspace domains (comma-separated, blank = all)
GOOGLE_OAUTH_ALLOWED_DOMAINS=
# Client-side Google Sign-In button
NEXT_PUBLIC_GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com

# ── Redis / Celery ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=django-db
CELERY_WORKER_CONCURRENCY=2
CELERY_TASK_ALWAYS_EAGER=False

# ── JWT ────────────────────────────────────────────────────────────────────────
JWT_ACCESS_LIFETIME_MINUTES=60
JWT_REFRESH_LIFETIME_DAYS=7

# ── CORS ───────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://13.54.2.137

# ── API tuning ─────────────────────────────────────────────────────────────────
API_PAGE_SIZE=50
THROTTLE_ANON=60/minute
THROTTLE_USER=300/minute

# ── Stripe ─────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_CAPITAL=price_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ── Plaid (bank connections) ───────────────────────────────────────────────────
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
PLAID_PRODUCTS=transactions,auth
PLAID_COUNTRY_CODES=IN,US

# ── Fraud / KYC (Sardine) ──────────────────────────────────────────────────────
SARDINE_API_KEY=
SARDINE_CLIENT_ID=
SARDINE_ENVIRONMENT=sandbox

# ── EmailJS (client-side OTP + confirmation emails) ───────────────────────────
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your_emailjs_public_key
NEXT_PUBLIC_EMAILJS_SERVICE_ID=service_xxxxxxx
NEXT_PUBLIC_EMAILJS_OTP_TEMPLATE=template_ft9ixwd
NEXT_PUBLIC_EMAILJS_CONFIRM_TEMPLATE=template_ojfe5ld

# ── App metadata ───────────────────────────────────────────────────────────────
APP_NAME=Headroom
FRONTEND_URL=http://localhost:3000
SUPPORT_EMAIL=support@headroom.finance
