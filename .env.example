# Database Configuration (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=headroom
DB_USER=postgres
DB_PASSWORD=postgres

# Application
NODE_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:3000

# API Gateway (Production)
NEXT_PUBLIC_API_GATEWAY_URL=https://your-api-gateway-id.execute-api.us-east-1.amazonaws.com/staging

# Service Endpoints (Local Development)
NEXT_PUBLIC_FORECAST_SERVICE_URL=http://localhost:8001
NEXT_PUBLIC_CREDIT_SERVICE_URL=http://localhost:8002
NEXT_PUBLIC_CAPITAL_SERVICE_URL=http://localhost:8003

# Session
SESSION_SECRET=your-secret-key-here-change-in-production

# AWS (for future cloud deployment)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Observability
DATADOG_API_KEY=
PAGERDUTY_API_KEY=
